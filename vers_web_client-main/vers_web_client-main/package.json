{
  "name": "react-app",
  "version": "0.1.0",
  "description": "VK Enterprises Software desktop and web client",
  "author": "VK Enterprises",
  "main": "electron/main.js",
  "private": true,
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.3",
    "@tanstack/react-virtual": "^3.3.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.6.8",
    "classnames": "^2.5.1",
    "csvtojson": "^2.0.10",
    "dayjs": "^1.11.10",
    "formik": "^2.4.5",
    "history": "^5.3.0",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "papaparse": "^5.4.1",
    "rctx-contextmenu": "^1.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropdown-select": "^4.11.2",
    "react-icons": "^5.2.1",
    "react-infinite-scroller": "^1.2.6",
    "react-leaflet": "^4.2.1",
    "react-modal": "^3.16.1",
    "react-otp-input": "^3.1.1",
    "react-redux": "^9.1.1",
    "react-router-dom": "^6.22.3",
    "react-scripts": "5.0.1",
    "react-toastify": "^10.0.5",
    "redux-persist": "^6.0.0",
    "sass": "^1.75.0",
    "serve-handler": "^6.1.6",
    "validator": "^13.11.0",
    "web-vitals": "^2.1.4",
    "yup": "^1.4.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "desktop:start": "electron .",
    "desktop:dev": "concurrently -k \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "desktop:build": "npm run build && electron-builder --win nsis",
    "desktop:pack": "npm run build && electron-builder --dir",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^3.4.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "extends": null,
    "appId": "in.vkrepo.car.desktop",
    "productName": "VK Enterprises Software",
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "desktop-release"
    },
    "win": {
      "icon": "public/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "VKEnterprisesSoftwareSetup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "installerHeaderIcon": "public/favicon.ico"
    }
  }
}
